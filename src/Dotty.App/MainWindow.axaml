<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Dotty.App.Controls;assembly=Dotty.App"
    x:Class="Dotty.App.MainWindow"
    Width="1000" Height="700"
    Title="Terminal (Phase 0)">
  <DockPanel>
  <controls:TerminalInput Name="InputControl" DockPanel.Dock="Bottom" />

  <controls:TerminalOutput Name="OutputBox" />
  </DockPanel>
</Window>
