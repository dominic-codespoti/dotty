<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Dotty.App.Controls.TerminalInput">

  <!-- Local styles for this control only -->
  <UserControl.Styles>

    <!-- Base style: remove normal TextBox border -->
    <Style Selector="TextBox">
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#D4D4D4" />
      <!-- Optional: kill transitions so nothing fades -->
      <Setter Property="Transitions">
        <Transitions />
      </Setter>
    </Style>

    <!-- Hit the inner border in the Fluent TextBox template -->
    <!-- Normal state -->
    <Style Selector="TextBox /template/ Border#PART_BorderElement">
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Opacity" Value="1" />
    </Style>

    <!-- Focus state -->
    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Opacity" Value="1" />
    </Style>

    <!-- Pointer-over state -->
    <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Opacity" Value="1" />
    </Style>

  </UserControl.Styles>

  <Border Background="{DynamicResource TerminalBackground}" Padding="6">
    <!-- Use a Grid so the prompt (cwd) sits inline left of the input box. The prompt is styled and has a tooltip for the full path. -->
    <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center">
      <TextBlock x:Name="PromptBlock"
                 VerticalAlignment="Center"
                 Margin="0,0,8,0"
                 Foreground="{DynamicResource TerminalForeground}"
                 FontFamily="{DynamicResource TerminalFontFamily}"
                 FontSize="{DynamicResource TerminalFontSize}"
                 TextTrimming="CharacterEllipsis" />

      <TextBox x:Name="PART_InputBox"
               Grid.Column="1"
               Background="Transparent"
               Foreground="{DynamicResource TerminalForeground}"
               FontFamily="{DynamicResource TerminalFontFamily}"
               FontSize="{DynamicResource TerminalFontSize}"
               AcceptsReturn="False"
               AcceptsTab="False"
               Watermark="" />
    </Grid>
  </Border>

</UserControl>
