<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Dotty.App.ViewModels"
        xmlns:controls="using:Dotty.App.Views"
        x:Class="Dotty.App.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Width="1000" Height="700"
        Title="Dotty">

    <Window.Styles>
        <Style Selector="TabStrip">
            <Setter Property="Background" Value="#181818" />
            <Setter Property="Padding" Value="4,4,4,0" />
            <Setter Property="MinHeight" Value="36" />
        </Style>
        <Style Selector="TabStripItem">
            <Setter Property="Foreground" Value="#999999" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="12,8,12,10" />
            <Setter Property="CornerRadius" Value="6,6,0,0" />
            <Setter Property="VerticalAlignment" Value="Bottom" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Height" Value="36" />
        </Style>
        <Style Selector="TabStripItem:pointerover">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="Foreground" Value="#DDDDDD" />
        </Style>
        <Style Selector="TabStripItem:selected">
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="TabStripItem:selected /template/ Border#PART_SelectedPipe">
            <Setter Property="IsVisible" Value="False" />
        </Style>
    </Window.Styles>

    <DockPanel>
        <Grid DockPanel.Dock="Top" Background="#181818">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                <TabStrip Name="TabBar" ItemsSource="{Binding Tabs}" SelectedItem="{Binding ActiveTab}">
                    <TabStrip.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Background="Transparent" MinWidth="60" Margin="0,0,0,0">
                                <StackPanel.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Rename Tab" Click="OnRenameTabClick" />
                                        <MenuItem Header="Duplicate Tab" Click="OnDuplicateTabClick" />
                                        <MenuItem Header="-" />
                                        <MenuItem Header="Close Tab" Click="OnCloseTabClick" />
                                        <MenuItem Header="Close Other Tabs" Click="OnCloseOtherTabsClick" />
                                    </ContextMenu>
                                </StackPanel.ContextMenu>
                                <TextBlock Text="●" Foreground="#555555" FontSize="10" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Title}" VerticalAlignment="Center" IsVisible="{Binding !IsEditingTitle}" />
                                <TextBox Text="{Binding Title}" VerticalAlignment="Center" IsVisible="{Binding IsEditingTitle}" 
                                         MinHeight="18" Padding="4,0" Margin="0" FontSize="13" 
                                         KeyUp="OnRenameTextBoxKeyUp" 
                                         LostFocus="OnRenameTextBoxLostFocus"
                                         PropertyChanged="OnRenameTextBoxPropertyChanged" />
                            </StackPanel>
                        </DataTemplate>
                    </TabStrip.ItemTemplate>
                </TabStrip>
            </ScrollViewer>

            <Button Grid.Column="1" Content="+" Click="OnNewTabRequested" 
                    Background="Transparent" Foreground="#999999" 
                    FontSize="20" Padding="16,0" VerticalAlignment="Stretch" HorizontalAlignment="Center" 
                    VerticalContentAlignment="Center" BorderThickness="0" Cursor="Hand">
                <Button.Styles>
                    <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                        <Setter Property="Background" Value="#2A2A2A" />
                        <Setter Property="Foreground" Value="#FFFFFF" />
                    </Style>
                </Button.Styles>
            </Button>
        </Grid>

        <!-- MANUAL CONTENT CONTAINER - No ContentControl, no DataTemplate binding -->
        <!-- We manage this manually in code-behind for full control -->
        <Grid Name="ContentContainer" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#1E1E1E">
            <!-- TerminalView instances will be added/removed here manually -->
        </Grid>
    </DockPanel>
</Window>
