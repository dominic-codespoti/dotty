<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="using:System"
             xmlns:controls="using:Dotty.App.Controls"
             x:Class="Dotty.App.App"
             RequestedThemeVariant="Dark">
    <Application.Resources>
        <SolidColorBrush x:Key="TerminalBackground" Color="#1E1E1E" />
        <FontFamily x:Key="TerminalFontFamily">JetBrainsMono Nerd Font</FontFamily>
        <x:Double x:Key="TerminalFontSize">13</x:Double>
        <Thickness x:Key="TerminalContentPadding">16,10,16,16</Thickness>
        <controls:TerminalCursorShape x:Key="TerminalCursorShape">Block</controls:TerminalCursorShape>
        <sys:TimeSpan x:Key="TerminalCursorBlinkInterval">00:00:00.600</sys:TimeSpan>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>